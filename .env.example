# Browser-visible API base URL for the standalone static app.
NEXT_PUBLIC_LOUDMUSIC_API_URL=

# Legacy/server-side backend settings kept for local experiments. Do not expose secrets with NEXT_PUBLIC_*.
AUDIO_TAGGING_API_URL=
AUDIO_TAGGING_CONNECT_TIMEOUT_SECONDS=45
AUDIO_TAGGING_UPLOAD_TIMEOUT_SECONDS=180
AUDIO_TAGGING_ANALYZE_TIMEOUT_SECONDS=120

# Server-side enrichment credentials. Never expose these with NEXT_PUBLIC_*.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
CHARTMETRIC_REFRESH_TOKEN=
